# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Environment files — secrets must never be committed
.env
.env.local
.env.*.local

# Apple notarization credentials for scripts/build-dmg.sh. The .example
# template is committed; the real file (with Issuer ID, Key ID, .p8 path)
# stays local — never commit it.
scripts/apple-notarize-env.sh

# Claude Code local settings (per-checkout, not project state)
.claude/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Git worktrees for parallel feature development (subagent-driven-development)
.worktrees/

# Python virtualenvs (per-developer; data/ingest/ creates one for the
# Wikipedia ingestion pipeline, but never commit it)
.venv/

# Python bytecode caches
__pycache__/
*.pyc

# Superpowers brainstorming session content (visual-companion mockups,
# per-session state). Persisted under .superpowers/brainstorm/ so
# mockups survive server restarts; never useful to ship in the repo.
.superpowers/
