# Copy this file to `.env` (which is gitignored) and fill in your real values.
# `cargo run --bin primer` loads `.env` automatically via dotenvy.

# Anthropic API key — required for `--backend cloud`.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default tracing filter (info, debug, trace).
# RUST_LOG=debug
